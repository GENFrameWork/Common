function(_gen_fail msg)
  message(FATAL_ERROR "[GEN Android] ${msg}")
endfunction()

function(_gen_strip_quotes in_var out_var)
  if(DEFINED ${in_var})
    set(_v "${${in_var}}")
  else()
    set(_v "")
  endif()
  string(STRIP "${_v}" _v)
  string(REGEX REPLACE "^\"(.*)\"$" "\\1" _v "${_v}")
  file(TO_CMAKE_PATH "${_v}" _v)
  set(${out_var} "${_v}" PARENT_SCOPE)
endfunction()

function(_gen_to_abs_value in_path base_dir out_var)
  set(_p "${in_path}")
  if(_p STREQUAL "")
    set(${out_var} "" PARENT_SCOPE)
    return()
  endif()
  file(TO_CMAKE_PATH "${_p}" _p)
  if(IS_ABSOLUTE "${_p}")
    set(_abs "${_p}")
  else()
    get_filename_component(_abs "${base_dir}/${_p}" ABSOLUTE)
    file(TO_CMAKE_PATH "${_abs}" _abs)
  endif()
  set(${out_var} "${_abs}" PARENT_SCOPE)
endfunction()

function(_gen_find_newest pattern_root pattern_glob out_var)
  if(NOT EXISTS "${pattern_root}")
    set(${out_var} "" PARENT_SCOPE)
    return()
  endif()
  file(GLOB_RECURSE _matches LIST_DIRECTORIES false "${pattern_root}/${pattern_glob}")
  if(_matches)
    list(SORT _matches COMPARE NATURAL ORDER DESCENDING)
    list(GET _matches 0 _first)
    file(TO_CMAKE_PATH "${_first}" _first)
    set(${out_var} "${_first}" PARENT_SCOPE)
  else()
    set(${out_var} "" PARENT_SCOPE)
  endif()
endfunction()

