set(_merge_ps1 "${_package_dir}/merge_payload.ps1")
file(WRITE  "${_merge_ps1}" "Add-Type -AssemblyName System.IO.Compression\n")
file(APPEND "${_merge_ps1}" "Add-Type -AssemblyName System.IO.Compression.FileSystem\n")
file(APPEND "${_merge_ps1}" "$apk = [System.IO.Path]::GetFullPath('${_unaligned_apk}')\n")
file(APPEND "${_merge_ps1}" "$pkg = [System.IO.Path]::GetFullPath('${_package_dir}')\n")
file(APPEND "${_merge_ps1}" "$zip = [System.IO.Compression.ZipFile]::Open($apk, [System.IO.Compression.ZipArchiveMode]::Update)\n")
file(APPEND "${_merge_ps1}" "try {\n")
file(APPEND "${_merge_ps1}" "  $pkgRoot = [System.IO.Path]::GetFullPath($pkg)\n")
file(APPEND "${_merge_ps1}" "  $pkgRootWithSep = $pkgRoot\n")
file(APPEND "${_merge_ps1}" "  if(-not $pkgRootWithSep.EndsWith([System.IO.Path]::DirectorySeparatorChar)) { $pkgRootWithSep += [System.IO.Path]::DirectorySeparatorChar }\n")
file(APPEND "${_merge_ps1}" "  $entries = @()\n")
file(APPEND "${_merge_ps1}" "  if(Test-Path (Join-Path $pkg 'lib')) { $entries += Get-ChildItem -Path (Join-Path $pkg 'lib') -Recurse -File }\n")
file(APPEND "${_merge_ps1}" "  if(Test-Path (Join-Path $pkg 'assets')) { $entries += Get-ChildItem -Path (Join-Path $pkg 'assets') -Recurse -File }\n")
file(APPEND "${_merge_ps1}" "  foreach($f in $entries) {\n")
file(APPEND "${_merge_ps1}" "    $full = [System.IO.Path]::GetFullPath($f.FullName)\n")
file(APPEND "${_merge_ps1}" "    if(-not $full.StartsWith($pkgRootWithSep)) { throw 'Entry fuera del directorio de paquete: ' + $full }\n")
file(APPEND "${_merge_ps1}" "    $rel = $full.Substring($pkgRootWithSep.Length).Replace('\\','/')\n")
file(APPEND "${_merge_ps1}" "    $existing = $zip.GetEntry($rel)\n")
file(APPEND "${_merge_ps1}" "    if($existing -ne $null) { $existing.Delete() }\n")
file(APPEND "${_merge_ps1}" "    $level = [System.IO.Compression.CompressionLevel]::Optimal\n")
file(APPEND "${_merge_ps1}" "    if($rel.StartsWith('lib/')) { $level = [System.IO.Compression.CompressionLevel]::NoCompression }\n")
file(APPEND "${_merge_ps1}" "    [System.IO.Compression.ZipFileExtensions]::CreateEntryFromFile($zip, $full, $rel, $level) | Out-Null\n")
file(APPEND "${_merge_ps1}" "  }\n")
file(APPEND "${_merge_ps1}" "}\n")
file(APPEND "${_merge_ps1}" "finally { if($zip -ne $null) { $zip.Dispose() } }\n")

find_program(_powershell_exec NAMES powershell pwsh REQUIRED)
